{
  "manifest_version": 3,
  "name": "KMU LMS Dark Mode",
  "version": "1.0",
  "description": "KMU LMS에 다크모드를 적용하는 확장 프로그램",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "content_scripts": [
    {
      "matches": ["*://*.kmu.ac.kr/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}